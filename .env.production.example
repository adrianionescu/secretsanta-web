# For future reference only — not used by the current GCP Cloud Run deployment.
# All env vars below are injected directly into Cloud Run via the GitHub Actions
# workflow (deploy_gcp.yml). If the CD pipeline is replaced (e.g. with a different
# provider or manual deploy), these are the env vars the backend requires.
#
# Copy this file to .env.production and fill in your values
# These are injected into Cloud Run via Secret Manager or inline env vars

# --- Backend (apps/backend) ---
PORT=3000
DB_PROVIDER=firestore
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_CLIENT_ID=your-google-oauth2-client-id
JWT_SECRET=your-strong-random-secret
