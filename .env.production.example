# Copy this file to .env.production and fill in your values
# These are injected into Cloud Run via Secret Manager or inline env vars

# --- Backend (apps/backend) ---
DB_PROVIDER=firestore
GCP_PROJECT_ID=your-gcp-project-id
PORT=3000

# The frontend Cloud Run service URL (set after first deploy)
FRONTEND_URL=https://secret-santa-web-xxxxx-uc.a.run.app
